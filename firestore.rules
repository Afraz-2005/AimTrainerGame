rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidSession(data) {
      return data.hostId is string &&
             data.status in ['waiting', 'playing', 'ended'] &&
             data.createdAt is number;
    }

    match /sessions/{sessionId} {
      allow read: if true; // Public for joining via code
      allow create: if isSignedIn() && isValidSession(request.resource.data);
      allow update: if isSignedIn(); // Simplified for MVP updates of pos/health
    }
  }
}
