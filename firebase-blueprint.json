{
  "entities": {
    "sessions": {
      "title": "Multiplayer Session",
      "description": "Represents a 2v2 multiplayer game session",
      "type": "object",
      "properties": {
        "hostId": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "playing", "ended"] },
        "createdAt": { "type": "number" },
        "players": { "type": "object" }
      },
      "required": ["hostId", "status", "createdAt", "players"]
    }
  },
  "firestore": {
    "/sessions/{sessionId}": {
      "schema": "sessions",
      "description": "2v2 game sessions"
    }
  }
}
